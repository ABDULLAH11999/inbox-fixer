# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# local JSON database states
/data/
*.json.bak
*.db
*.sqlite

# large media assets (videos & high-res assets usually > 100mb)
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.pdf.bak

# compressed archives (often > 100mb)
*.zip
*.rar
*.tar.gz
*.7z
*.iso
*.dmg

# virtual machines / disk images
*.vmdk
*.vdi
*.qcow2

# misc / systems
.DS_Store
*.pem
.env*
.vercel
*.tsbuildinfo
next-env.d.ts

# debug / error logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
